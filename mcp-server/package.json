{
  "name": "@tmhs/docker-mcp",
  "version": "0.4.0",
  "description": "MCP server for Docker CLI integration - 36 tools for containers, images, compose, volumes, networks, and system info. Full container lifecycle, image pipeline, and Compose V2 management.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docker-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
